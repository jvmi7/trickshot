{
  // Typechecks the Bun sidecar + the shared protocol module. The main tsconfig
  // only covers `src/**` (the webview), and `bun build --compile` transpiles
  // WITHOUT typechecking — so without this, the sidecar half of the hand-mirrored
  // Rust<->TS protocol had no compile-time net. Run via `bun run check:sidecar`
  // (and in CI). The thin per-platform `agent.<platform>.ts` embed shims are
  // excluded: they use Bun-only `import ... with { type: 'file' }` attributes and
  // carry no protocol logic.
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ESNext", "DOM"],
    "types": ["node"]
  },
  "include": ["sidecar/core.ts", "sidecar/providers/**/*.ts", "shared/**/*.ts"],
  // Test files import `bun:test` (Bun globals, not in the node typings); they are
  // run + checked by `bun test`, so keep them out of this tsc pass.
  "exclude": ["sidecar/**/*.test.ts"]
}
